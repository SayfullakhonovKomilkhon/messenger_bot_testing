# Messenger backend base URL (no trailing slash)
MESSENGER_API_URL=https://your-api.railway.app

# Bot token from app / POST /api/v1/bots (header: Authorization: Bot <token>)
BOT_TOKEN=

# Optional: for getMessages / sendMessage tests
# CONVERSATION_ID=

# Optional: UUID of a human user to test startConversation
# TARGET_USER_ID=

# Public URL of this service webhook path (set after Railway deploy), e.g. https://xxx.up.railway.app/webhook
# WEBHOOK_PUBLIC_URL=

# Webhook server: 1 = reply with echo when a message arrives
ECHO_REPLY=1
