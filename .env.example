# Bot API base URL: bot-gateway public URL (no trailing slash, no /api/v1)
# Core still serves /api/v1/bots with JWT; /api/v1/bot/* is only on gateway
# Example: gateway on same VPS port 3001, or Railway service URL for gateway
MESSENGER_API_URL=http://127.0.0.1:3001

# Optional: core URL for owner bot CRUD (POST /api/v1/bots) if different from gateway
# MESSENGER_CORE_URL=http://127.0.0.1:3000

# Bot token from app / POST /api/v1/bots (header: Authorization: Bot <token>)
BOT_TOKEN=

# Optional: for getMessages / sendMessage tests
# CONVERSATION_ID=

# Optional: UUID of a human user to test startConversation
# TARGET_USER_ID=

# Public URL of this service (must match Flutter AppConstants.defaultBotWebhookUrl)
# WEBHOOK_PUBLIC_URL=https://web-production-88dcc.up.railway.app/webhook

# Webhook server: 1 = reply with echo when a message arrives
ECHO_REPLY=1
